    <VerticalScrollView rectAlignment="LowerCenter" offsetXY="0 14" width="596" height="448" horizontal="false" horizontalScrollbarVisibility="None" scrollSensitivity="30" color="rgba(0,0,0,0.35)">
        <TableLayout autoCalculateHeight="true" cellSpacing="0" padding="4 8 4 4" columnWidths="560" cellBackgroundColor="rgba(0,0,0,0)">
            <Row id="PatchNotesRow" preferredHeight="1100"><Cell>
                <Text id="PatchNotesText" fontSize="17" color="rgb(0.9,0.9,0.9)" alignment="UpperLeft" text="Loading..." />
