<Panel
    id="SearchTypePanel"
    width="300"
    height="370"
    rectAlignment="MiddleCenter"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    returnToOriginalPositionWhenReleased="false"
    allowDragging="true"
    color="rgba(0.1,0.1,0.1,1)"
    visibility=""
    active="False"
    >
    <Text
      id="STtext"
      offsetXY="0 -5"
      fontSize="40"
      color="rgb(1,1,1)"
      text="select type(s)    to look for"
      alignment="UpperCenter" />

    <InputField
      color="rgb(0.25,0.25,0.25)"
      textColor="rgb(1,1,1)"
      caretColor="rgb(1,1,1)"
      placeholder="enter custom type"
      characterValidation="Alphanumeric"
      onEndEdit="UItypeCustom"
      id="typeCustom"
      width="140"
      height="30"
      fontSize="15"
      offsetXY="0 70"
      alignment="MiddleCenter"
    />

    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="60"
      height="27.5"
      fontSize="20"
      offsetXY="-90 37.5"
      id="land"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Land"
    />
    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="90"
      height="27.5"
      fontSize="20"
      offsetXY="-10 37.5"
      id="creature"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Creature"
    />
    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="80"
      height="27.5"
      fontSize="20"
      offsetXY="80 37.5"
      id="artifact"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Artifact"
    />
    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="130"
      height="27.5"
      fontSize="20"
      offsetXY="-67.5 5"
      id="enchantment"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Enchantment"
    />
    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="130"
      height="27.5"
      fontSize="20"
      offsetXY="67.5 5"
      id="planeswalker"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Planeswalker"
    />
    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="90"
      height="27.5"
      fontSize="20"
      offsetXY="-47.5 -27.5"
      id="instant"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Instant"
    />
    <ToggleButton
      isOn="false"
      onValueChanged="UItypeToggle"
      colors="rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)|rgb(0.3,0.3,0.3)"
      selectedBackgroundColor="rgb(0.5,0.5,0.2)"
      deselectedBackgroundColor="rgb(0.25,0.25,0.25)"
      width="90"
      height="27.5"
      fontSize="20"
      offsetXY="47.5 -27.5"
      id="sorcery"
      textColor="rgb(1,1,1)"
      alignment="MiddleCenter"
      text="Sorcery"
    />

    <HorizontalLayout
      width="165"
      height="30"
      spacing="-15"
      offsetXY="-5 -70"
      alignment="LowerCenter"
      childAlignment="MiddleCenter">
        <Text fontSize="20" color="rgb(1,1,1)">repeat</Text>
        <InputField
          id="repeatX"
          color="rgb(0.3,0.3,0.3)"
          textOffset="8 8 5 0"
          textColor="rgb(1,1,1)"
          caretColor="rgb(1,1,1)"
          characterValidation="Integer"
          onEndEdit="UIrepeatSearchType"
          placeholder="X"
          tooltip="enter number to repeat the search procedure that many times"
          tooltipPosition="Below"
          tooltipBorderColor="rgba(0,0,0,0)"
          fontSize="20"/>
        <Text fontSize="20" color="rgb(1,1,1)">times</Text>
    </HorizontalLayout>

    <Button
      onClick="STokay"
      offsetXY="50 10"
      text="✓"
      rectAlignment="LowerCenter"
      width="80"
      height="80"
      fontSize="60"
      textColor="rgb(0,0.6,0)"
      textAlignment="MiddleCenter"
      colors="rgb(0.25,0.25,0.25)|rgb(0.35,0.35,0.35)|rgb(0.5,0.5,0.5)|rgb(0.5,0.5,0.5)"
    />
    <Button
      onClick="STcancel"
      offsetXY="-50 10"
      text="✗"
      rectAlignment="LowerCenter"
      width="80"
      height="80"
      fontSize="60"
      textColor="rgb(1,0,0)"
      textAlignment="MiddleCenter"
      colors="rgb(0.25,0.25,0.25)|rgb(0.35,0.35,0.35)|rgb(0.5,0.5,0.5)|rgb(0.5,0.5,0.5)"
    />
</Panel>

<Panel
    id="GetValuePanel"
    width="300"
    height="330"
    rectAlignment="MiddleCenter"
    showAnimation="FadeIn"
    hideAnimation="FadeOut"
    returnToOriginalPositionWhenReleased="false"
    allowDragging="true"
    color="rgba(0.1,0.1,0.1,1)"
    visibility=""
    active="False"
    >
    <Text
      id="CMtext"
      offsetXY="0 -10"
      fontSize="40"
      color="rgb(1,1,1)"
      text="enter amount
            to scry for"
      alignment="UpperCenter" />
    <InputField
      id="CMinput"
      alignment="MiddleCenter"
      maxLength="2"
      offsetXY="0 15"
      width="150"
      height="80"
      fontSize="60"
      textAlignment="MiddleCenter"
      characterValidation="Integer"
      placeholder="here"
      onSubmit="CMokay"
      characterLimit="2"
      onEndEdit="CMgetVal"
    />

    <HorizontalLayout
      width="165"
      height="30"
      spacing="-15"
      offsetXY="-5 -50"
      alignment="LowerCenter"
      childAlignment="MiddleCenter">
        <Text fontSize="20" color="rgb(1,1,1)">repeat</Text>
        <InputField
          id="repeatCascadeX"
          color="rgb(0.3,0.3,0.3)"
          textOffset="8 8 5 0"
          textColor="rgb(1,1,1)"
          caretColor="rgb(1,1,1)"
          characterValidation="Integer"
          onEndEdit="UIrepeatCascade"
          placeholder="X"
          tooltip="enter number to repeat the search procedure that many times"
          tooltipPosition="Below"
          tooltipBorderColor="rgba(0,0,0,0)"
          fontSize="20"/>
        <Text fontSize="20" color="rgb(1,1,1)">times</Text>
    </HorizontalLayout>

    <Button
      onClick="CMokay"
      offsetXY="50 10"
      text="✓"
      rectAlignment="LowerCenter"
      width="80"
      height="80"
      fontSize="60"
      textColor="rgb(0,0.6,0)"
      textAlignment="MiddleCenter"
      colors="rgb(0.25,0.25,0.25)|rgb(0.35,0.35,0.35)|rgb(0.5,0.5,0.5)|rgb(0.5,0.5,0.5)"
    />
    <Button
      onClick="CMcancel"
      offsetXY="-50 10"
      text="✗"
      rectAlignment="LowerCenter"
      width="80"
      height="80"
      fontSize="60"
      textColor="rgb(1,0,0)"
      textAlignment="MiddleCenter"
      colors="rgb(0.25,0.25,0.25)|rgb(0.35,0.35,0.35)|rgb(0.5,0.5,0.5)|rgb(0.5,0.5,0.5)"
    />
</Panel>

<!-- Scryfall search bar -->
<Defaults>
    <Panel class="WindowBorder" color="#8F8478" outline="#635351" outlineSize="2 -2" />
    <Row class="MenuBar" color="#666666" width="385"/>
    <Button class="topButtons" width="25" height="25" color="#eeeeee" />
    <Text class="UIText" fontSize="18" fontStyle="Bold" color="#000000" />
    <TableLayout class="SearchTable" rectAlignment="LowerCenter" cellPadding="5" color="#FFFFFF" columnWidths="130 0" />
    <Row class="SearchTableRow" preferredHeight="40" />
    <InputField class="UIInputField" fontSize="14" colors="#FFFFFF|#dddddd|#FFFFFF|rgba(0.78,0.78,0.78,0.5)" />
    <Button class="FAB" color="#4286f4" />
    <ToggleButton class="UIToggleButton" iconAlignment="Right" padding="5" transition="None" isOn="True" />
</Defaults>
<Panel id="SearchPanel" class="WindowBorder" width="385" height="310" rectAlignment="MiddleCenter" showAnimation="FadeIn" hideAnimation="FadeOut" returnToOriginalPositionWhenReleased="false" allowDragging="true" color="#666666" visibility="" active="False">
    <Row id="MenuBar" class="MenuBar" width="385">
        <Text id="WindowTitle" class="UIText" text="MTG Card Spawner" color="#FFFFFF" rectAlignment="UpperCenter" alignment="LowerCenter" width="230" height="80" offsetXY="0 55" />
        <Button id="closeButton" class="topButtons" rectAlignment="UpperRight" color="#990000" textColor="#FFFFFF" text="X" onClick="close" />
    </Row>
    <TableLayout id="SearchTable" class="SearchTable" height="280">
        <Row class="SearchTableRow">
            <Cell>
                <Text>Name</Text>
            </Cell>
            <Cell>
                <InputField id="vName" class="UIInputField" onEndEdit="updateText" />
            </Cell>
        </Row>
        <Row class="SearchTableRow">
            <Cell>
                <Text>CMC</Text>
            </Cell>
            <Cell>
                <InputField id="vCmc" class="UIInputField" onEndEdit="updateText" />
            </Cell>
        </Row>
        <Row class="SearchTableRow">
            <Cell>
                <Text>Power</Text>
            </Cell>
            <Cell>
                <InputField id="vPower" class="UIInputField" onEndEdit="updateText" />
            </Cell>
        </Row>
        <Row class="SearchTableRow">
            <Cell>
                <Text>Toughness</Text>
            </Cell>
            <Cell>
                <InputField id="vToughness" class="UIInputField" onEndEdit="updateText" />
            </Cell>
        </Row>
        <Row class="SearchTableRow">
            <Cell>
                <Text>Color</Text>
            </Cell>
            <Cell>
                <HorizontalLayout spacing="5">
                    <ToggleButton id="vWhite" class="UIToggleButton" icon="whiteMana" color="#fffbd5" onValueChanged="updatevColor" />
                    <ToggleButton id="vBlue" class="UIToggleButton" icon="blueMana" color="#aae0fa" onValueChanged="updatevColor" />
                    <ToggleButton id="vBlack" class="UIToggleButton" icon="blackMana" color="#cbc2bf" onValueChanged="updatevColor" />
                    <ToggleButton id="vRed" class="UIToggleButton" icon="redMana" color="#f9aa8f" onValueChanged="updatevColor" />
                    <ToggleButton id="vGreen" class="UIToggleButton" icon="greenMana" color="#9bd3ae" onValueChanged="updatevColor" />
                    <ToggleButton id="vColorless" class="UIToggleButton" icon="colorlessMana" color="#ccc2c0" onValueChanged="updatevColor" />
                </HorizontalLayout>
            </Cell>
        </Row>
        <Row class="SearchTableRow">
            <Cell>
                <Text>Type</Text>
            </Cell>
            <Cell>
                <ToggleGroup>
                    <HorizontalLayout>
                        <Toggle id="vToken" class="UIToggleField" onValueChanged="updateType" isOn="False">Token</Toggle>
                        <Toggle id="vEmblem" class="UIToggleField" onValueChanged="updateType" isOn="False">Emblem</Toggle>
                        <Toggle id="vOther" class="UIToggleField" onValueChanged="updateType" isOn="True">Other</Toggle>
                </HorizontalLayout>
                </ToggleGroup>
            </Cell>
        </Row>
		<Row class="SearchTableRow">
            <Cell columnSpan = "2">
                <Button id="search" class="FAB" onClick="search">
                    <Text>Search</Text>
                </Button>
            </Cell>
        </Row>
    </TableLayout>
</Panel>


<!--DECK IMPORTER-->
<Panel id="ListPanel" class="WindowBorder" width="385" height="490" rectAlignment="MiddleCenter" showAnimation="FadeIn" hideAnimation="FadeOut" returnToOriginalPositionWhenReleased="false" allowDragging="true" color="#666666" visibility="" active="False">
    <Row id="ListMenuBar" class="MenuBar" width="385">
        <Text id="ListWindowTitle" class="UIText" text="MTG Deck Importer" color="#FFFFFF" rectAlignment="UpperCenter" alignment="LowerCenter" width="230" height="80" offsetXY="0 55" />
        <Button id="ListCloseButton" class="topButtons" rectAlignment="UpperRight" color="#990000" textColor="#FFFFFF" text="X" onClick="close" />
    </Row>
    <TableLayout id="ListTable" class="SearchTable" height="460" width="385" columnWidths="385">
        <Row>
            <Cell>
                <Text>Add deck list below in standard text format.</Text>
            </Cell>
        </Row>
        <Row preferredHeight="350">
            <Cell>
                <InputField id="vDeckList" class="UIInputField" lineType="MultiLineNewLine" text="" onEndEdit="updateText" />
            </Cell>
        </Row>
        <Row>
            <Cell>
                <Button id="ListImport" class="FAB" onClick="getDeckList">
                    <Text>Import</Text>
                </Button>
            </Cell>
        </Row>
    </TableLayout>
</Panel>

<!-- PATCH NOTES -->
<Panel id="PatchNotesPanel" width="620" height="520" rectAlignment="MiddleCenter" showAnimation="FadeIn" hideAnimation="FadeOut" returnToOriginalPositionWhenReleased="false" allowDragging="true" color="rgba(0.1,0.1,0.1,0.97)" outline="#635351" outlineSize="2 -2" visibility="" active="False">
    <VerticalLayout padding="14 14 14 14" spacing="10" childForceExpandWidth="true" childForceExpandHeight="false">
        <Panel preferredHeight="44" minHeight="44" flexibleHeight="0">
            <Text id="PatchNotesTitle" fontSize="28" fontStyle="Bold" color="rgb(1,1,1)" alignment="MiddleCenter" text="Patch Notes" />
            <Button id="PatchNotesCloseButton" rectAlignment="UpperRight" width="34" height="34" color="#990000" textColor="#FFFFFF" text="X" fontSize="20" onClick="closePatchNotes" />
        </Panel>
        <VerticalScrollView color="rgba(0,0,0,0.35)" flexibleHeight="1" scrollSensitivity="30">
            <Text id="PatchNotesText" fontSize="17" color="rgb(0.9,0.9,0.9)" alignment="UpperLeft" text="Loading..." preferredHeight="1100" />
        </VerticalScrollView>
    </VerticalLayout>
</Panel>

<!-- SETTINGS -->
<!-- always-on gear button; each player opens their own private settings panel -->
<Button id="settingsGear" onClick="openSettings" text="&#9881;"
    rectAlignment="LowerRight" offsetXY="-61 6" width="46" height="46" fontSize="28"
    color="rgba(0.1,0.1,0.1,0.85)" textColor="#FFFFFF"
    tooltip="Player settings" tooltipPosition="Left" tooltipBorderColor="rgba(0,0,0,0)" />

<Panel id="SettingsPanel" width="380" height="660" rectAlignment="MiddleCenter" showAnimation="FadeIn" hideAnimation="FadeOut" returnToOriginalPositionWhenReleased="false" allowDragging="true" color="rgba(0.1,0.1,0.1,0.97)" outline="#635351" outlineSize="2 -2" visibility="" active="False">
    <VerticalLayout padding="16 16 16 16" spacing="12" childForceExpandWidth="true" childForceExpandHeight="false">
        <Panel preferredHeight="40" minHeight="40" flexibleHeight="0">
            <Text fontSize="26" fontStyle="Bold" color="rgb(1,1,1)" alignment="MiddleCenter" text="Player Settings" />
            <Button rectAlignment="UpperRight" width="30" height="30" color="#990000" textColor="#FFFFFF" text="X" fontSize="18" onClick="closeSettings" />
        </Panel>

        <Text fontSize="14" fontStyle="Bold" color="#6fa0d8" alignment="MiddleLeft" preferredHeight="20" minHeight="20" flexibleHeight="0" text="TRIGGERS" />
        <VerticalLayout spacing="0" preferredHeight="44" minHeight="44" flexibleHeight="0" childForceExpandHeight="false">
            <Toggle id="setOppDrawTriggers" isOn="False" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="26" minHeight="26">Opponent-draw trigger alerts</Toggle>
            <Text color="#e0a030" fontSize="13" alignment="MiddleLeft" preferredHeight="16" minHeight="16" margin="24 0 0 0" text="unfinished, somewhat buggy" />
        </VerticalLayout>

        <Text fontSize="14" fontStyle="Bold" color="#6fa0d8" alignment="MiddleLeft" preferredHeight="20" minHeight="20" flexibleHeight="0" text="STATE-BASED" />
        <Toggle id="setDrawSkipReminder" isOn="True" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="30" minHeight="30">Draw-step skip reminder</Toggle>
        <VerticalLayout spacing="0" preferredHeight="44" minHeight="44" flexibleHeight="0" childForceExpandHeight="false">
            <Toggle id="setAbilityRestrictions" isOn="False" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="26" minHeight="26">Can't-activate-ability reminder</Toggle>
            <Text color="#e0a030" fontSize="13" alignment="MiddleLeft" preferredHeight="16" minHeight="16" margin="24 0 0 0" text="unfinished, somewhat buggy" />
        </VerticalLayout>
        <VerticalLayout spacing="0" preferredHeight="44" minHeight="44" flexibleHeight="0" childForceExpandHeight="false">
            <Toggle id="setSearchRestrictions" isOn="True" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="26" minHeight="26">Tutor/search restriction (blocks fetch)</Toggle>
            <Text color="#9aa0a8" fontSize="13" alignment="MiddleLeft" preferredHeight="16" minHeight="16" margin="24 0 0 0" text="fetchland to grave, resolve manually" />
        </VerticalLayout>

        <Text fontSize="14" fontStyle="Bold" color="#6fa0d8" alignment="MiddleLeft" preferredHeight="20" minHeight="20" flexibleHeight="0" text="DISPLAY" />
        <Toggle id="setLandTracker" isOn="True" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="30" minHeight="30">Land-entered tracker</Toggle>
        <Toggle id="setFetchPreviews" isOn="True" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="30" minHeight="30">Fetchland previews</Toggle>

        <Text fontSize="14" fontStyle="Bold" color="#6fa0d8" alignment="MiddleLeft" preferredHeight="20" minHeight="20" flexibleHeight="0" text="COMMANDER" />
        <VerticalLayout spacing="0" preferredHeight="44" minHeight="44" flexibleHeight="0" childForceExpandHeight="false">
            <Toggle id="setCommanderQOL" isOn="True" onValueChanged="settingsToggle" textColor="rgb(0.9,0.9,0.9)" fontSize="17" preferredHeight="26" minHeight="26">Commander QOL buttons</Toggle>
            <Text color="#9aa0a8" fontSize="13" alignment="MiddleLeft" preferredHeight="16" minHeight="16" margin="24 0 0 0" text="Etali trigger / Ral grid, applied next game" />
        </VerticalLayout>

        <HorizontalLayout minHeight="36" preferredHeight="36" flexibleHeight="0" spacing="8" childAlignment="MiddleLeft" childForceExpandWidth="false">
            <Text fontSize="17" color="rgb(0.9,0.9,0.9)" alignment="MiddleLeft" flexibleWidth="1" minWidth="220" text="Reveal reset (seconds)" />
            <InputField id="setRevealResetSecs" characterValidation="Integer" onEndEdit="settingsRevealReset" text="30" minWidth="64" preferredWidth="64" flexibleWidth="0" fontSize="17" textAlignment="MiddleCenter" color="rgb(0.25,0.25,0.25)" textColor="rgb(1,1,1)" caretColor="rgb(1,1,1)" />
        </HorizontalLayout>
    </VerticalLayout>
</Panel>

<!-- HOST SETTINGS -->
<!-- host-only gear (gold), sits left of the per-player gear -->
<Button id="hostGear" onClick="openHostSettings" text="&#9881;"
    rectAlignment="LowerRight" offsetXY="-113 6" width="46" height="46" fontSize="28"
    color="rgba(0.1,0.1,0.1,0.85)" textColor="#e0a030"
    tooltip="Host settings (host only)" tooltipPosition="Left" tooltipBorderColor="rgba(0,0,0,0)" />

<Panel id="HostSettingsPanel" width="430" height="388" rectAlignment="MiddleCenter" showAnimation="FadeIn" hideAnimation="FadeOut" returnToOriginalPositionWhenReleased="false" allowDragging="true" color="rgba(0.1,0.1,0.1,0.97)" outline="#e0a030" outlineSize="2 -2" visibility="" active="False">
    <VerticalLayout padding="16 16 14 16" spacing="8" childForceExpandWidth="true" childForceExpandHeight="false">
        <Panel preferredHeight="38" minHeight="38" flexibleHeight="0">
            <Text fontSize="24" fontStyle="Bold" color="#e0a030" alignment="MiddleCenter" text="Host Settings" />
            <Button rectAlignment="UpperRight" width="30" height="30" color="#990000" textColor="#FFFFFF" text="X" fontSize="18" onClick="closeHostSettings" />
        </Panel>
        <Text fontSize="12" color="#9aa0a8" alignment="MiddleCenter" preferredHeight="16" minHeight="16" text="Enforce forces a setting on all players and locks their toggle." />

        <HorizontalLayout preferredHeight="20" minHeight="20" flexibleHeight="0" spacing="6" childForceExpandWidth="false" childAlignment="MiddleLeft">
            <Text fontSize="12" fontStyle="Bold" color="#6fa0d8" alignment="MiddleCenter" minWidth="52" preferredWidth="52" flexibleWidth="0" text="ENF" />
            <Text fontSize="12" fontStyle="Bold" color="#6fa0d8" alignment="MiddleCenter" minWidth="42" preferredWidth="42" flexibleWidth="0" text="ON" />
            <Text fontSize="12" fontStyle="Bold" color="#6fa0d8" alignment="MiddleLeft" flexibleWidth="1" text="SETTING" />
        </HorizontalLayout>

        <HorizontalLayout preferredHeight="30" minHeight="30" flexibleHeight="0" spacing="6" childForceExpandWidth="false" childAlignment="MiddleLeft">
            <Toggle id="hostEnf_oppDrawTriggers" isOn="False" onValueChanged="hostToggleEnforced" minWidth="52" preferredWidth="52" flexibleWidth="0" />
            <Toggle id="hostVal_oppDrawTriggers" isOn="False" interactable="false" onValueChanged="hostToggleValue" minWidth="42" preferredWidth="42" flexibleWidth="0" />
            <Text fontSize="15" color="rgb(0.9,0.9,0.9)" alignment="MiddleLeft" flexibleWidth="1" text="Opponent-draw trigger alerts" />
        </HorizontalLayout>
        <HorizontalLayout preferredHeight="30" minHeight="30" flexibleHeight="0" spacing="6" childForceExpandWidth="false" childAlignment="MiddleLeft">
            <Toggle id="hostEnf_drawSkipReminder" isOn="False" onValueChanged="hostToggleEnforced" minWidth="52" preferredWidth="52" flexibleWidth="0" />
            <Toggle id="hostVal_drawSkipReminder" isOn="False" interactable="false" onValueChanged="hostToggleValue" minWidth="42" preferredWidth="42" flexibleWidth="0" />
            <Text fontSize="15" color="rgb(0.9,0.9,0.9)" alignment="MiddleLeft" flexibleWidth="1" text="Draw-step skip reminder" />
        </HorizontalLayout>
        <HorizontalLayout preferredHeight="30" minHeight="30" flexibleHeight="0" spacing="6" childForceExpandWidth="false" childAlignment="MiddleLeft">
            <Toggle id="hostEnf_abilityRestrictions" isOn="False" onValueChanged="hostToggleEnforced" minWidth="52" preferredWidth="52" flexibleWidth="0" />
            <Toggle id="hostVal_abilityRestrictions" isOn="False" interactable="false" onValueChanged="hostToggleValue" minWidth="42" preferredWidth="42" flexibleWidth="0" />
            <Text fontSize="15" color="rgb(0.9,0.9,0.9)" alignment="MiddleLeft" flexibleWidth="1" text="Can't-activate-ability reminder" />
        </HorizontalLayout>
